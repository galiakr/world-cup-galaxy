# ── Supabase (Required) ────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── football-data.org (Required for squads & top scorers) ──────────────────
# Get from: football-data.org/client/register — free forever, no credit card
FOOTBALL_DATA_KEY=your_football_data_key

# ── OpenWeather (Required for weather forecasts) ─────────────────────────────
# Get from: openweathermap.org → your account → API keys
OPENWEATHER_API_KEY=your_openweather_api_key

# ── App URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
